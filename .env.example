# Copy to .env.local and adjust. Required by the backend (Personal Information profile).
MONGODB_URI=mongodb://127.0.0.1:27017/spicyocean

# Auth
# AUTH_SECRET: long random string used to sign session JWTs (generate your own)
AUTH_SECRET=change-me-to-a-long-random-string
# SIGNUP_CODE: the static creation password required to register a new account
SIGNUP_CODE=spicyocean-create
